# Copy to ".env" in the project root (same folder as package.json). The file ".env" is gitignored.
#
# OpenRouter — used for "Summarize with AI" on Search Records (optional).
# `yarn start` / `yarn build` read this via scripts/ng-with-openrouter-env.cjs (nothing is written into src/).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
